# ============================================================
# Stacks 全局可选环境变量
#
# 使用方法：
#   cp .env.example .env  并按需修改
#
# .env 不会被 git 跟踪（见 .gitignore），仅本机生效
# ============================================================

# 各镜像 tag（不设置则使用各自 compose 中的默认 latest）
# TRAEFIK_TAG=v3.7
# PORTAINER_TAG=sts
