# Stacks 仓库忽略规则
#
# 仓库只跟踪 infra/、services/_template/ 和根目录的 Makefile/README/.gitignore。
# 真实业务服务（services/<name>/）由 /services/* 整体屏蔽。

# 业务服务目录
/services/*
!/services/_template/

# 环境变量真实值（infra 下的 .env 例外，需入库以锁定版本）
**/.env
!**/.env.example
!infra/**/.env

# IDE / 编辑器
**/.claude/settings.local.json
.vscode/
.idea/
*.swp
.DS_Store
